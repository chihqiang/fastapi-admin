# ================================================= #
# *************** FastAPI Admin 配置 *************** #
# ================================================= #

# ================================================= #
# ******************* 服务器配置 ****************** #
# ================================================= #
PROJECT_NAME=FastAPI Admin
API_V1_PREFIX=/api/v1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ================================================= #
# ******************** 日志配置 ******************** #
# ================================================= #
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_FILE=
OPERATION_LOG_RECORD=true
IGNORE_OPERATION_FUNCTION=
OPERATION_RECORD_METHOD=["POST","PUT","PATCH","DELETE","HEAD","OPTIONS"]

# ================================================= #
# ******************* 登录认证配置 ****************** #
# ================================================= #
# 密钥（生产环境必须修改）
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================================= #
# ******************** 数据库配置 ******************* #
# ================================================= #
# 数据库类型: mysql / postgres / sqlite
DATABASE_TYPE=sqlite
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=fastapi

# 数据库连接池配置
DATABASE_ECHO=false
ECHO_POOL=false
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_TIMEOUT=30
POOL_RECYCLE=1800
POOL_USE_LIFO=true
POOL_PRE_PING=true
FUTURE=true
AUTOCOMMIT=false
AUTOFETCH=false
EXPIRE_ON_COMMIT=false

# ================================================= #
# ******************** 跨域配置 ******************** #
# ================================================= #
CORS_ORIGIN_ENABLE=true
# 生产环境请修改为具体域名列表，如: ["https://admin.example.com"]
ALLOW_ORIGINS=["*"]
ALLOW_METHODS=["*"]
ALLOW_HEADERS=["*"]
ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=["X-Request-ID"]

# ================================================= #
# ******************* Gzip压缩配置 ******************* #
# ================================================= #
GZIP_ENABLE=true
GZIP_MIN_SIZE=1000
GZIP_COMPRESS_LEVEL=9
